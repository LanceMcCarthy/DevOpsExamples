<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiDemo.Controls"
             xmlns:viewModels="clr-namespace:MauiDemo.ViewModels"
             x:Class="MauiDemo.Views.MarkdownPage"
             x:DataType="viewModels:MarkdownPageViewModel"
             Title="Markdown Viewer">

    <controls:MarkdownViewer MarkdownText="{Binding MarkdownText}"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill" />

</ContentPage>
